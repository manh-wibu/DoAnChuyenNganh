# =========================================
# Unity Project .gitignore
# =========================================

# --- Unity generated folders (KHÔNG push) ---
Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/
MemoryCaptures/
CrashReports/
Recordings/
Cache/
sysinfo.txt

# --- Asset Store tools ---
AssetStoreTools*

# --- Visual Studio / Rider / IDE files ---
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb

# --- Autogenerated build results ---
*.apk
*.aab
*.app
*.xcworkspace
*.xcuserstate

# --- OS-specific files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Unity meta and settings that nên giữ lại ---
# ✅ KHÔNG ignore các thư mục này:
!Assets/
!ProjectSettings/
!Packages/

# --- Git LFS (tùy chọn nếu dùng file lớn) ---
*.psd
*.fbx
*.mp4
*.wav
*.png
*.jpg
